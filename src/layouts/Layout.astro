---
import '../styles/main.css';
import '../styles/layout.css';
import '../styles/components.css';

import UserStats from '../components/UserStats.jsx';

const { title = "TSSR Memo - Plateforme de Révision" } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content="Plateforme de révision interactive pour Techniciens Systèmes et Réseaux (TSSR)">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
    <header class="app-header">
        <div class="container header-content">
            <a href="/" class="logo-group">
                <span class="logo-icon">🖥️</span>
                <span class="logo-text">TSSR<strong>Memo</strong></span>
            </a>
            <div style="display: flex; align-items: center; gap: var(--space-6); flex-wrap: wrap;">
                <nav aria-label="Navigation principale" class="header-nav">
                    <a href="/dashboard" class={`nav-btn ${Astro.url.pathname.includes('/dashboard') ? 'active' : ''}`}>Révisions</a>
                    <a href="/" class={`nav-btn ${Astro.url.pathname === '/' ? 'active' : ''}`}>À propos</a>
                    <a href="/avis" class={`nav-btn ${Astro.url.pathname === '/avis' ? 'active' : ''}`}>Avis</a>
                </nav>
                <UserStats client:load />
            </div>
        </div>
    </header>

    <main class={`container ${Astro.props.containerClass || ''}`}>
        <div id="app-content">
            <slot />
        </div>
    </main>

    <footer class="app-footer">
        <div class="container">
            <p>&copy; 2026 TSSR Memo - Devenir Technicien en Systèmes et Réseaux</p>
        </div>
    </footer>
    <style is:global>
        ::view-transition-old(root),
        ::view-transition-new(root) {
            animation-duration: 0.3s;
        }
    </style>
    <script>
        document.addEventListener('click', (e) => {
            const img = e.target;
            if (img && img.closest('.lesson-content') && img.tagName === 'IMG') {
                window.open(img.src, '_blank');
            }
        });
    </script>
</body>
</html>
